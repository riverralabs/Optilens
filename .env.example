# ═══════════════════════════════════════════
# OPTILENS — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Anthropic
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub App
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY=

# Redis (Upstash)
REDIS_URL=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry
SENTRY_DSN=
VITE_SENTRY_DSN=

# Security (min 32 characters for AES-256)
ENCRYPTION_KEY=

# Frontend (Vite prefix required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:8000

# Kill Switches (set to true to disable)
KILL_GITHUB_AGENT=false
KILL_REVENUE_FIGURES=false
KILL_AUDIT_QUEUE=false
KILL_HEATMAP_INGEST=false

# Application
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
